{
  "manifest_version": 3,
  "name": "GA Hub Poll Shortcut",
  "version": "1.5",
  "description": "Quick access to the community poll creator and auto-insert polls into comments.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": [
        "https://hub.griffpatch.academy/*",
        "https://speechless-parrot.github.io/ga-polls/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
